# Proyecto Supabase remoto real (no una instancia local): las pruebas E2E
# (apps/web/e2e) autentican contra estos valores, así que el proyecto
# apuntado debe tener sembrados los usuarios de apps/web/e2e/data/users.ts
# (ana@/marta@/admin@readhub.test, contraseña Password123!). En CI estos
# mismos valores se inyectan vía GitHub Secrets: SUPABASE_URL,
# SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY (ver .github/workflows/ci.yml).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Voyage AI (embeddings, voyage-4) y Groq (LLM, llama-3.3-70b-versatile por
# defecto, ver GROQ_MODEL). Sin prefijo NEXT_PUBLIC_: son server-only. Una
# vez el prompt 06 reemplace embedding.service.ts/chat.service.ts, las
# variables OPENAI_API_KEY/ANTHROPIC_API_KEY de arriba dejan de usarse.
VOYAGE_API_KEY=
GROQ_API_KEY=
GROQ_MODEL=
